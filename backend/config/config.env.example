# This is a example .env file for use in local development.
# Duplicate this file as .env in the root of the project and update the environment variables to match your desired config

# The HTTP port to run the application on
PORT=4000

# MongoDB connection string
MONGO_URI=mongodb+srv://jaiparjapati101_db_user:TRHHwbWIqBfRV5CD@cluster0.fgnwjlb.mongodb.net/?appName=Cluster0

# JWT secret and expiry
JWT_SECRET=WFFWf15115U842UGUBWF81EE858UYBY51BGBJ5E51Q
JWT_EXPIRE=7d

# Cookie expiry
COOKIE_EXPIRE=5

# Razorpay Credentials
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
RAZORPAY_WEBHOOK_SECRET=

# Any SMTP Credentials (Optional) **Alternative Sendgrid**
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SERVICE=gmail
SMTP_MAIL=jhondoe@gmail.com
SMTP_PASSWORD=password@123

# Sendgrid Credentials
SENDGRID_API_KEY=SG.apikey
SENDGRID_MAIL=jhondoe@gmail.com
SENDGRID_RESET_TEMPLATEID=d-sf5sf7s1g5ff8fd87df48dferg1
SENDGRID_ORDER_TEMPLATEID=d-sf5sf7s1g5ff8fd87df48df51eg
SENDGRID_PASSWORD_CHANGED_TEMPLATEID=d-your_password_changed_template

# Frontend base URL (used for password reset links and payment redirects)
FRONTEND_URL=http://localhost:3000

# Cloudinary Credentials
CLOUDINARY_NAME=store
CLOUDINARY_API_KEY=7467848571151
CLOUDINARY_API_SECRET=secret_key

# Dev-only: workaround for corporate proxies that break outbound TLS and cause
# "unable to get local issuer certificate" during Cloudinary uploads.
# Recommended fix is to configure Node to trust your proxy/root CA (NODE_EXTRA_CA_CERTS).
# Never enable in production.
CLOUDINARY_INSECURE_TLS=false

# Testimonials
# Max image size (in bytes) for community testimonials uploads
TESTIMONIAL_IMAGE_MAX_BYTES=5000000

# Community Banner
# Max image size (in bytes) for Lexi Community banner uploads
COMMUNITY_BANNER_IMAGE_MAX_BYTES=6000000

# Dev-only: bypass payments and simulate success (never enable in production)
# MOCK_PAYMENTS=false

# OpenAI (Lexy AI assistant)
# If not set, the chat UI still works but replies will be non-AI fallback.
OPENAI_API_KEY=sk-your_key_here
OPENAI_MODEL=gpt-4o-mini

# Voice: Speech-to-Text (Whisper)
# Cost safety: disabled by default. Browser Web Speech API is used instead (free).
ENABLE_PAID_VOICE_TRANSCRIPTION=false

# Voice: Text-to-Speech (OpenAI TTS)
# Cost safety: disabled by default. Browser speechSynthesis is used instead (free).
# Enable for premium voice quality (uses OPENAI_API_KEY).
ENABLE_PAID_TTS=false
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova

# Azure OpenAI (Lexy AI assistant)
# If set, Lexy will prefer Azure OpenAI over OPENAI_API_KEY.
# Use the resource endpoint (e.g., https://<resource>.openai.azure.com/) or any full URL from the portal;
# only the origin is used and the request path is built from DEPLOYMENT + API_VERSION.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your_azure_key_here
AZURE_OPENAI_DEPLOYMENT=your_deployment_name
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Fragrance Finder (GPT-assisted selection)
# Uses AZURE_OPENAI_* or OPENAI_API_KEY. If neither is set, falls back to deterministic ranking.
LEXY_FRAGRANCE_MODEL=gpt-4o-mini
LEXY_FRAGRANCE_GPT_CANDIDATE_LIMIT=18

# Make My Kit (GPT-assisted selection)
# Uses AZURE_OPENAI_* or OPENAI_API_KEY. If neither is set, falls back to deterministic ranking.
LEXY_MAKE_MY_KIT_MODEL=gpt-4o-mini
# How many products to fetch per category before final picking.
LEXY_MAKE_MY_KIT_PER_CATEGORY_LIMIT=12
# Max IDs accepted from GPT when picking from candidates.
LEXY_MAKE_MY_KIT_GPT_PICK_LIMIT=18

# Google Sign-in (OAuth)
# Create an OAuth client in Google Cloud Console and set the same client ID in frontend + backend.
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# Meilisearch (Product search)
# Run locally via: docker compose -f docker-compose.meili.yml up -d
MEILI_HOST=http://127.0.0.1:7700
MEILI_API_KEY=DEV_MEILI_MASTER_KEY_CHANGE_ME
MEILI_PRODUCTS_INDEX=products
# Optional: enable verbose Meili error logging in backend
MEILI_LOGGING=false
# Optional: batch size for reindex script
MEILI_REINDEX_BATCH_SIZE=1000

# WhatsApp provider
#   meta   - Meta WhatsApp Business Cloud API (default)
#   twilio - Twilio WhatsApp (uses TWILIO_WHATSAPP_FROM)
WHATSAPP_PROVIDER=meta

# Meta WhatsApp Business Cloud API
# If WHATSAPP_ACCESS_TOKEN and WHATSAPP_PHONE_NUMBER_ID are not set, WhatsApp sending is skipped.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_VERSION=v22.0

# Allow free-form text messages (used for dev/testing or Twilio)
WHATSAPP_ALLOW_TEXT=false

# Optional: template language and template names (recommended for transactional sends)
WHATSAPP_TEMPLATE_LANGUAGE=en
WHATSAPP_TEMPLATE_ORDER_PLACED=
WHATSAPP_TEMPLATE_ORDER_SHIPPED=
WHATSAPP_TEMPLATE_ORDER_DELIVERED=

# Twilio WhatsApp sender (sandbox or production)
# Example sandbox: whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=

# The environment to run the application in
NODE_ENV=development